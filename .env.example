# API / single Render Web Service
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=verify-full

# Admin authentication
# ADMIN_API_KEY is the initial moderation login credential.
# ADMIN_SESSION_SECRET signs the HTTP-only admin session cookie.
# Use separate long random values in production and never commit the real values.
ADMIN_API_KEY=replace-with-a-long-random-admin-password
ADMIN_SESSION_SECRET=replace-with-a-different-long-random-session-secret

# Signs the one-hour evidence upload/finalize token returned after report creation.
# Use another long random value in production.
EVIDENCE_UPLOAD_SECRET=replace-with-a-long-random-upload-secret

# Admin login protection. Defaults: 6 attempts per 15 minutes per client IP.
ADMIN_LOGIN_RATE_LIMIT_MAX=6
ADMIN_LOGIN_RATE_LIMIT_WINDOW_MS=900000

# Automatic agency email delivery (Resend)
# Create and verify the sending domain/address in Resend before using it here.
RESEND_API_KEY=re_replace_with_real_key
REPORT_FROM_EMAIL=VoiceMap Fresno <reports@your-verified-domain.example>
REPORT_REPLY_TO=

# Comma/semicolon/newline-separated addresses are supported in every recipient variable.
# Configure the actual current official addresses in Render. Do not leave all recipients blank.
REPORT_TO_ANIMAL_CENTER=
REPORT_TO_POLICE=
REPORT_TO_COUNCIL=
REPORT_TO_CITY=
REPORT_NOTIFICATION_RECIPIENTS=

# Reporter contact is excluded from agency emails by default and remains private in moderation.
REPORT_INCLUDE_REPORTER_CONTACT=false

# Evidence stays private in Neon. Email attachments stop at this aggregate byte limit;
# any remaining files stay available to authenticated moderators.
REPORT_MAX_EMAIL_ATTACHMENT_BYTES=10485760

# Comma-separated browser origins allowed to call the API.
# Optional when the API and frontend are served from the same Web Service origin.
CORS_ORIGINS=http://localhost:5173

# Optional override for the built frontend directory served by the API.
# FRONTEND_DIST_DIR=/absolute/path/to/artifacts/voicemap-fresno/dist/public

# Public report intake protection.
# Defaults: 8 requests per 15-minute window per client IP.
# Creation, evidence upload, and finalization all use the intake limiter.
INTAKE_RATE_LIMIT_MAX=8
INTAKE_RATE_LIMIT_WINDOW_MS=900000

# Identical report content submitted within this window returns the existing receipt.
# Default: 2 minutes.
INTAKE_DUPLICATE_WINDOW_MS=120000

# Frontend build
# Leave VITE_API_URL unset for same-origin Render Web Service deployment.
# Use it only for local dev or split-origin deployments.
VITE_API_URL=http://localhost:3000
BASE_PATH=/
