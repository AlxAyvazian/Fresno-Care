# API / single Render Web Service
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Use a long, randomly generated secret. Never commit the real value.
ADMIN_API_KEY=replace-with-a-long-random-secret

# Comma-separated browser origins allowed to call the API.
# Optional when the API and frontend are served from the same Web Service origin.
CORS_ORIGINS=http://localhost:5173

# Optional override for the built frontend directory served by the API.
# FRONTEND_DIST_DIR=/absolute/path/to/artifacts/voicemap-fresno/dist/public

# Public report intake protection.
# Defaults: 8 submissions per 15-minute window per client IP.
INTAKE_RATE_LIMIT_MAX=8
INTAKE_RATE_LIMIT_WINDOW_MS=900000

# Identical report content submitted within this window returns the existing receipt.
# Default: 2 minutes.
INTAKE_DUPLICATE_WINDOW_MS=120000

# Frontend build
# Leave VITE_API_URL unset for same-origin Render Web Service deployment.
# Use it only for local dev or split-origin deployments.
VITE_API_URL=http://localhost:3000
BASE_PATH=/
